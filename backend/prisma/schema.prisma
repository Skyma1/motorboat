generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  DISPATCHER
  CAPTAIN
}

enum BoatStatus {
  FREE
  ON_TRIP
  MAINTENANCE
}

enum PaymentMethod {
  CASH
  TRANSFER
  ACQUIRING
}

enum TripStatus {
  CREATED
  IN_PROGRESS
  COMPLETED
}

enum DockingType {
  PRIVATE
  CITY
}

model User {
  id           String   @id @default(cuid())
  name         String
  phone        String?  @unique
  email        String?  @unique
  passwordHash String
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  captainBoat          BoatCaptain?
  captainRate          CaptainRate?
  tripsAsCaptain       Trip[]         @relation("CaptainTrips")
  tripsAsDispatcher    Trip[]         @relation("DispatcherTrips")
  expenses             Expense[]
  partTimeWorks        PartTimeWork[]
  fuelExpenses         FuelExpense[]
  cashHandovers        CashHandover[] @relation("CashHandoverCaptain")
  cashHandoversEdited  CashHandover[] @relation("CashHandoverEditedBy")
  dailyBalances        DailyBalance[]

  @@map("users")
}

model Boat {
  id        String     @id @default(cuid())
  name      String
  status    BoatStatus @default(FREE)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  captain BoatCaptain?
  trips   Trip[]

  @@map("boats")
}

model BoatCaptain {
  id        String   @id @default(cuid())
  boatId    String   @unique
  captainId String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boat    Boat @relation(fields: [boatId], references: [id], onDelete: Cascade)
  captain User @relation(fields: [captainId], references: [id], onDelete: Cascade)

  @@map("boat_captains")
}

model Pier {
  id        String   @id @default(cuid())
  name      String
  cost      Float    @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips Trip[]

  @@map("piers")
}

model CaptainRate {
  id          String   @id @default(cuid())
  captainId   String   @unique
  hourlyRate  Float    @default(1600)
  exitPayment Float    @default(2500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  captain User @relation(fields: [captainId], references: [id], onDelete: Cascade)

  @@map("captain_rates")
}

model Trip {
  id              String        @id @default(cuid())
  boatId          String
  captainId       String
  dispatcherId    String?
  pierId          String?
  price           Float
  paymentMethod   PaymentMethod
  status          TripStatus    @default(CREATED)
  startedAt       DateTime?
  endedAt         DateTime?
  durationMinutes Float?
  captainSalary   Float?
  pierCost        Float         @default(0)
  dockingType     DockingType?
  cityDockHours   Float?
  profit          Float?
  date            String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  boat          Boat           @relation(fields: [boatId], references: [id])
  captain       User           @relation("CaptainTrips", fields: [captainId], references: [id])
  dispatcher    User?          @relation("DispatcherTrips", fields: [dispatcherId], references: [id])
  pier          Pier?          @relation(fields: [pierId], references: [id])
  partTimeWorks PartTimeWork[]
  fuelExpenses  FuelExpense[]

  @@map("trips")
}

model Expense {
  id        String   @id @default(cuid())
  captainId String
  amount    Float
  comment   String
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  captain User @relation(fields: [captainId], references: [id], onDelete: Cascade)

  @@map("expenses")
}

model PartTimeWork {
  id        String   @id @default(cuid())
  captainId String
  tripId    String?
  amount    Float
  comment   String
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  captain User  @relation(fields: [captainId], references: [id], onDelete: Cascade)
  trip    Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@map("part_time_works")
}

model FuelExpense {
  id        String   @id @default(cuid())
  captainId String
  tripId    String?
  liters    Float?
  amount    Float
  comment   String
  date      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  captain User  @relation(fields: [captainId], references: [id], onDelete: Cascade)
  trip    Trip? @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@map("fuel_expenses")
}

model CashHandover {
  id                   String    @id @default(cuid())
  captainId            String
  forDate              String
  amount               Float
  receiverText         String
  createdByCaptainAt   DateTime  @default(now())
  editedByDispatcherAt DateTime?
  editedByDispatcherId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  captain    User   @relation("CashHandoverCaptain", fields: [captainId], references: [id], onDelete: Cascade)
  dispatcher User?  @relation("CashHandoverEditedBy", fields: [editedByDispatcherId], references: [id], onDelete: SetNull)

  @@unique([captainId, forDate])
  @@map("cash_handovers")
}

model DailyBalance {
  id            String    @id @default(cuid())
  captainId     String
  date          String
  cashIncome    Float     @default(0)
  captainSalary Float     @default(0)
  exitPayment   Float     @default(0)
  expensesTotal Float     @default(0)
  balance       Float     @default(0)
  isClosed      Boolean   @default(false)
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  captain User @relation(fields: [captainId], references: [id], onDelete: Cascade)

  @@unique([captainId, date])
  @@map("daily_balances")
}
